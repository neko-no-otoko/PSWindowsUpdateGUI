<Window
    x:Class="PSWindowsUpdateGui.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PSWindowsUpdate GUI">
    <Grid x:Name="RootGrid" Background="{ThemeResource AppPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{ThemeResource AppHeaderBrush}" Padding="20,12" RowSpacing="8">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="PSWindowsUpdate GUI" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"><Run Text="{Binding EngineVersion}"/><Run Text="  &#x2022;  "/><Run Text="{Binding Identity}"/><Run Text="  &#x2022;  "/><Run Text="{Binding ElevationDisplay}"/></TextBlock>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding TargetDisplay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Theme" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                <ComboBox Width="110" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" AutomationProperties.Name="Application theme"/>
                <Button Content="About" Click="About_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Target" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <ToggleSwitch OffContent="Local" OnContent="Remote" IsOn="{Binding IsRemote, Mode=TwoWay}"/>
                <TextBox Width="200" Text="{Binding ComputerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsRemote}" PlaceholderText="computer.contoso.test" AutomationProperties.Name="Remote computer DNS name"/>
                <CheckBox Content="HTTPS" IsChecked="{Binding UseWinRmHttps, Mode=TwoWay}" IsEnabled="{Binding IsRemote}" VerticalAlignment="Center"/>
                <Button Content="Test connection" Command="{Binding TestTargetCommand}"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PersistenceNotice}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" MaxWidth="360" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <NavigationView x:Name="MainNavigation" Grid.Row="1" PaneDisplayMode="Top" IsBackButtonVisible="Collapsed" IsSettingsVisible="False" SelectionChanged="MainNavigation_SelectionChanged" Background="Transparent">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Updates" Tag="updates"/>
                <NavigationViewItem Content="History &amp; Status" Tag="history"/>
                <NavigationViewItem Content="Services &amp; Policies" Tag="services"/>
                <NavigationViewItem Content="Offline &amp; Maintenance" Tag="offline"/>
                <NavigationViewItem Content="Operation Explorer" Tag="operations"/>
                <NavigationViewItem Content="Logs" Tag="logs"/>
            </NavigationView.MenuItems>
            <NavigationView.Content>
                <Grid Padding="14,8,14,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <Grid x:Name="UpdatesPage">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Scan options" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Source" VerticalAlignment="Center"/><ComboBox Width="180" ItemsSource="{Binding SourceOptions}" SelectedItem="{Binding SelectedSource, Mode=TwoWay}"/>
                                    <TextBlock Text="Title regex" VerticalAlignment="Center"/><TextBox Width="220" Text="{Binding TitleFilter, Mode=TwoWay}"/>
                                    <TextBlock Text="KB IDs" VerticalAlignment="Center"/><TextBox Width="150" Text="{Binding KBFilter, Mode=TwoWay}"/>
                                    <Button Content="Scan" Command="{Binding ScanCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8"><CheckBox Content="Drivers only" IsChecked="{Binding DriversOnly, Mode=TwoWay}"/><CheckBox Content="Include hidden" IsChecked="{Binding IncludeHidden, Mode=TwoWay}"/><CheckBox Content="Accept unaccepted license terms" IsChecked="{Binding AcceptEulas, Mode=TwoWay}"/></StackPanel>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1" Margin="4,8">
                            <Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Background="{ThemeResource AppSubtleBrush}" CornerRadius="6,6,0,0" Padding="10,0">
                                <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="85"/><ColumnDefinition Width="120"/><ColumnDefinition Width="90"/><ColumnDefinition Width="125"/><ColumnDefinition Width="125"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Select" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="1" Text="Type" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="2" Text="KB" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="3" Text="Size" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="4" Text="Provider" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="5" Text="Version" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="6" Text="Title" Style="{StaticResource TableHeaderTextStyle}"/></Grid>
                            </Border>
                            <ListView Grid.Row="1" ItemsSource="{Binding Updates}" SelectionMode="None" ItemContainerStyle="{StaticResource StretchListViewItemStyle}" AutomationProperties.Name="Available Windows updates">
                                <ListView.ItemTemplate><DataTemplate><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="85"/><ColumnDefinition Width="120"/><ColumnDefinition Width="90"/><ColumnDefinition Width="125"/><ColumnDefinition Width="125"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"/><TextBlock Grid.Column="1" Text="{Binding Type}" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding Kb}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="3" Text="{Binding Size}" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="{Binding DriverProvider}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="5" Text="{Binding DriverVersion}" VerticalAlignment="Center"/><TextBlock Grid.Column="6" Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/></Grid></DataTemplate></ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4"><TextBlock Text="Selections are revalidated by GUID and revision. Automatic reboot is disabled." Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="8"/><Button Content="Hide" Command="{Binding HideCommand}"/><Button Content="Unhide" Command="{Binding UnhideCommand}"/><Button Content="Download" Command="{Binding DownloadCommand}"/><Button Content="Uninstall" Command="{Binding UninstallCommand}"/><Button Content="Install selected" Command="{Binding InstallCommand}" Style="{StaticResource PrimaryButtonStyle}"/></StackPanel>
                    </Grid>

                    <Grid x:Name="HistoryPage" Visibility="Collapsed" RowSpacing="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="History &amp; Status" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="Read directly from Windows Update Agent; entries might not appear in the Windows Settings workflow." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"><Button Content="Refresh status" Command="{Binding RefreshStatusCommand}" Style="{StaticResource PrimaryButtonStyle}"/><Button Content="Refresh history" Command="{Binding HistoryCommand}"/><Button Content="Registered services" Command="{Binding ServicesCommand}"/></StackPanel></Grid>
                        <Grid Grid.Row="1" Height="88" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}"><StackPanel><TextBlock Text="Computer" Style="{StaticResource CaptionTextStyle}"/><TextBlock Text="{Binding CurrentStatus.ComputerName}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/></StackPanel></Border>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorderStyle}"><StackPanel><TextBlock Text="WUA version" Style="{StaticResource CaptionTextStyle}"/><TextBlock Text="{Binding CurrentStatus.AgentVersionDisplay}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/></StackPanel></Border>
                            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardBorderStyle}"><StackPanel><TextBlock Text="Update service" Style="{StaticResource CaptionTextStyle}"/><TextBlock Text="{Binding CurrentStatus.UpdateServiceStatus}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/></StackPanel></Border>
                            <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource CardBorderStyle}"><StackPanel><TextBlock Text="Installer" Style="{StaticResource CaptionTextStyle}"/><TextBlock Text="{Binding CurrentStatus.InstallerState}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/></StackPanel></Border>
                            <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource CardBorderStyle}"><StackPanel><TextBlock Text="Restart" Style="{StaticResource CaptionTextStyle}"/><TextBlock Text="{Binding CurrentStatus.RebootState}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/></StackPanel></Border>
                            <Border Grid.Row="0" Grid.Column="5" Style="{StaticResource CardBorderStyle}"><StackPanel><TextBlock Text="Target-local time" Style="{StaticResource CaptionTextStyle}"/><TextBlock Text="{Binding CurrentStatus.LocalTimeDisplay}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/></StackPanel></Border>
                        </Grid>
                        <TextBlock Grid.Row="2" Text="{Binding RegisteredServicesSummary}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="8,0"/>
                        <Grid Grid.Row="3" Margin="4"><Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border Background="{ThemeResource AppSubtleBrush}" CornerRadius="6,6,0,0" Padding="10,0"><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="145"/><ColumnDefinition Width="100"/><ColumnDefinition Width="145"/><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><TextBlock Text="Date (local)" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="1" Text="Operation" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="2" Text="Result" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="3" Text="Title" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="4" Text="Client" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="5" Text="HRESULT" Style="{StaticResource TableHeaderTextStyle}"/></Grid></Border><ListView Grid.Row="1" ItemsSource="{Binding HistoryEntries}" SelectedItem="{Binding SelectedHistoryEntry, Mode=TwoWay}" SelectionMode="Single" ItemContainerStyle="{StaticResource StretchListViewItemStyle}" AutomationProperties.Name="Windows Update history"><ListView.ItemTemplate><DataTemplate><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="145"/><ColumnDefinition Width="100"/><ColumnDefinition Width="145"/><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><TextBlock Text="{Binding DateDisplay}"/><TextBlock Grid.Column="1" Text="{Binding OperationDisplay}"/><TextBlock Grid.Column="2" Text="{Binding ResultDisplay}"/><TextBlock Grid.Column="3" Text="{Binding Title}" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="4" Text="{Binding Client}" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="5" Text="{Binding HResultDisplay}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView></Grid>
                        <Border Grid.Row="4" Height="150" Style="{StaticResource CardBorderStyle}"><Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="330"/></Grid.ColumnDefinitions><StackPanel Spacing="2"><TextBlock Text="SELECTED HISTORY ENTRY" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold"/><TextBlock Text="{Binding SelectedHistoryEntry.Title}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding SelectedHistoryEntry.IdentityDisplay}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="{Binding SelectedHistoryEntry.RemovalStatus}" TextWrapping="Wrap" MaxLines="2"/><TextBlock Text="History is an audit record; rollback exists only when uninstalling exposes a previous Windows-managed package." Foreground="{ThemeResource WarningBrush}" TextWrapping="Wrap" MaxLines="2"/></StackPanel><StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="Verification source" VerticalAlignment="Center"/><ComboBox Width="170" Height="32" ItemsSource="{Binding SourceOptions}" SelectedItem="{Binding SelectedSource, Mode=TwoWay}"/></StackPanel><Button Height="32" Content="Check removal" Command="{Binding CheckHistoryRemovalCommand}" HorizontalAlignment="Stretch"/><Button Height="32" Content="Uninstall / roll back selected" Command="{Binding UninstallHistoryCommand}" Style="{StaticResource DangerButtonStyle}" HorizontalAlignment="Stretch"/></StackPanel></Grid></Border>
                    </Grid>

                    <Grid x:Name="ServicesPage" Visibility="Collapsed" RowSpacing="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Services &amp; Policies" Style="{StaticResource TitleTextBlockStyle}"/><StackPanel Orientation="Horizontal" Spacing="4"><Button Content="List update services" Command="{Binding ServicesCommand}"/><Button Content="Register Microsoft Update" Command="{Binding AddMicrosoftUpdateCommand}"/></StackPanel></StackPanel><TextBlock Grid.Row="1" Text="Policy changes &#x2014; one validated Name=Value per line; use Name=remove to delete:"/><TextBox Grid.Row="2" Text="{Binding PolicyChanges, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" FontFamily="Consolas" TextWrapping="NoWrap" ScrollViewer.VerticalScrollBarVisibility="Auto" AutomationProperties.Name="Windows Update policy changes"/><StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Preview policy" Command="{Binding PreviewPolicyCommand}"/><Button Content="Apply policy" Command="{Binding ApplyPolicyCommand}" Style="{StaticResource PrimaryButtonStyle}"/></StackPanel></Grid>

                    <StackPanel x:Name="OfflinePage" Visibility="Collapsed" Spacing="12" Margin="8"><TextBlock Text="Offline &amp; Maintenance" Style="{StaticResource TitleTextBlockStyle}"/><InfoBar IsOpen="True" Severity="Informational" Title="Offline assessment" Message="wsusscn2.cab contains security-update metadata, not update payloads." IsClosable="False"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Text="{Binding OfflineCabPath, Mode=TwoWay}" PlaceholderText="Path to wsusscn2.cab" IsEnabled="{Binding IsLocal}" AutomationProperties.Name="Offline scan CAB path"/><Button Grid.Column="1" Content="Browse&#x2026;" Click="BrowseOfflineCab_Click" IsEnabled="{Binding IsLocal}"/></Grid><StackPanel Orientation="Horizontal" Spacing="4"><Button Content="Download latest CAB" Command="{Binding DownloadOfflineCatalogCommand}" IsEnabled="{Binding IsLocal}"/><Button Content="Run offline scan" Command="{Binding OfflineScanCommand}" IsEnabled="{Binding IsLocal}" Style="{StaticResource PrimaryButtonStyle}"/><Button Content="Reset Windows Update components" Command="{Binding ResetComponentsCommand}"/></StackPanel><TextBlock Text="Scheduling, payload export, service removal, policy restore, reporting, and remote automation remain available through the validated CLI." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/><Button Content="CLI help" HorizontalAlignment="Left" Click="CliHelp_Click"/></StackPanel>

                    <Grid x:Name="OperationsPage" Visibility="Collapsed"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="38"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Typed operation catalog" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="The GUI and CLI share this validation catalog and stable JSON contracts." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/></StackPanel><Border Grid.Row="1" Background="{ThemeResource AppSubtleBrush}" CornerRadius="6,6,0,0" Padding="10,0" Margin="4,8,4,0"><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="150"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Operation" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="1" Text="Category" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="2" Text="Modifies state" Style="{StaticResource TableHeaderTextStyle}"/><TextBlock Grid.Column="3" Text="Description" Style="{StaticResource TableHeaderTextStyle}"/></Grid></Border><ListView Grid.Row="2" ItemsSource="{Binding Operations}" SelectionMode="None" ItemContainerStyle="{StaticResource StretchListViewItemStyle}" AutomationProperties.Name="Native operation catalog"><ListView.ItemTemplate><DataTemplate><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="150"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Name}"/><TextBlock Grid.Column="1" Text="{Binding Category}"/><CheckBox Grid.Column="2" IsChecked="{Binding Mutating}" IsEnabled="False"/><TextBlock Grid.Column="3" Text="{Binding Description}" TextWrapping="Wrap"/></Grid></DataTemplate></ListView.ItemTemplate></ListView><TextBlock Grid.Row="3" Text="All modifying commands support --plan and require confirmation. Raw scripts are never accepted." Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="8"/></Grid>

                    <Grid x:Name="LogsPage" Visibility="Collapsed"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Export visible log&#x2026;" Click="ExportLogs_Click"/><Button Content="Clear logs" Command="{Binding ClearLogsCommand}"/></StackPanel><TextBox Grid.Row="1" Text="{Binding LogText}" IsReadOnly="True" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"/></Grid>
                </Grid>
            </NavigationView.Content>
        </NavigationView>

        <Grid Grid.Row="2" Padding="16,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" VerticalAlignment="Center"/><Button Grid.Column="1" Width="220" Content="Cancel / stop monitoring" Command="{Binding CancelCommand}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibility}}"/></Grid>
        <TextBox Grid.Row="3" Height="140" Margin="16,4" Text="{Binding OutputText}" IsReadOnly="True" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" AutomationProperties.Name="Operation output" Visibility="{Binding IsOperationOutputVisible, Converter={StaticResource BooleanToVisibility}}"/>
        <ProgressBar Grid.Row="4" Height="4" Minimum="0" Maximum="100" Value="{Binding Progress}"/>
    </Grid>
</Window>
