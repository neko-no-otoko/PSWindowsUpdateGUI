<Application x:Class="PSWindowsUpdateGui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:PSWindowsUpdateGui.Infrastructure"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />

        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F5F7FA" />

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="6,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="6" />
        </Style>
    </Application.Resources>
</Application>
