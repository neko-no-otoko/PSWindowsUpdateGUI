<Application
    x:Class="PSWindowsUpdateGui.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:infra="using:PSWindowsUpdateGui.Infrastructure">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
                <ResourceDictionary Source="Themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <infra:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <infra:BoolToVisibilityConverter x:Key="BooleanToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
